{
  "name": "@designjs/bridge",
  "version": "0.1.0",
  "description": "Shared Zod schemas + WebSocket protocol constants for the DesignJS MCP server and canvas runtime.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "keywords": [
    "designjs",
    "mcp",
    "model-context-protocol",
    "grapesjs",
    "design-to-code",
    "schema"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubychilds/DesignJS.git",
    "directory": "packages/bridge"
  },
  "homepage": "https://github.com/rubychilds/DesignJS/tree/main/packages/bridge#readme",
  "bugs": "https://github.com/rubychilds/DesignJS/issues",
  "publishConfig": {
    "access": "public"
  }
}
