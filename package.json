{
  "name": "opencanvas",
  "version": "0.1.0-dev",
  "private": true,
  "description": "Open-source MCP design canvas that gives AI coding agents eyes",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @opencanvas/bridge build && pnpm --filter @opencanvas/app dev",
    "build": "pnpm --filter @opencanvas/bridge build && pnpm -r --filter '!@opencanvas/bridge' build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "mcp": "pnpm --filter @opencanvas/bridge build && pnpm --filter @opencanvas/mcp-server start",
    "smoke:bridge": "pnpm --filter @opencanvas/bridge build && node scripts/smoke-bridge.mjs"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "ws": "^8.20.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
