{
  "name": "@designjs/mcp-server",
  "version": "0.1.0",
  "description": "stdio Model Context Protocol (MCP) server for DesignJS — lets Claude Code, Cursor, and any MCP-compatible agent read and write a live HTML/CSS design canvas.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "designjs-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc -b"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@designjs/bridge": "workspace:*",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "designjs",
    "mcp",
    "model-context-protocol",
    "anthropic",
    "claude",
    "cursor",
    "grapesjs",
    "design-to-code",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubychilds/DesignJS.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/rubychilds/DesignJS/tree/main/packages/mcp-server#readme",
  "bugs": "https://github.com/rubychilds/DesignJS/issues",
  "publishConfig": {
    "access": "public"
  }
}
