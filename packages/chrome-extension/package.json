{
  "name": "@designjs/chrome-extension",
  "version": "0.1.0-dev",
  "private": true,
  "description": "DesignJS Chrome extension — capture any web element and drop it onto the DesignJS canvas as editable HTML. Implements PRD Epic 8 per ADR-0011.",
  "scripts": {
    "build": "webpack --mode=development",
    "build:prod": "NODE_ENV=production webpack --mode=production",
    "dev": "webpack --mode=development --watch",
    "package": "NODE_ENV=production webpack --mode=production && cd dist && zip -r ../designjs-extension.zip .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.2",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.22.15",
    "@babel/preset-typescript": "^7.22.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/chrome": "^0.1.30",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.2",
    "jsdom": "^23.0.0",
    "postcss": "^8.5.9",
    "postcss-loader": "^8.2.1",
    "style-loader": "^3.3.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vitest": "^1.0.0",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1"
  }
}
